rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Rules untuk koleksi menu
    match /menu/{menuId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Rules untuk koleksi orders
    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read: if isAdmin();
      allow update: if isAdmin();
    }
    
    // Rules untuk koleksi admins - pake email hardcoded untuk bootstrap
    match /admins/{userId} {
      allow read: if isAdmin() || isBootstrapAdmin();
      allow write: if isBootstrapAdmin(); // Hanya bootstrap admin yang bisa manage admins
    }
    
    // Function helpers
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Bootstrap admin untuk setup awal
    function isBootstrapAdmin() {
      return request.auth != null && 
             request.auth.token.email == 'allmight@pempekdomino.com';
    }
  }
}